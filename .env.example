# Anthropic API key for the reasoning-agent bots and the coach reflection pass.
ANTHROPIC_API_KEY=sk-ant-...

# Model used for fast in-hand decisions.
DECISION_MODEL=claude-sonnet-4-6

# Stronger model for the post-session reflection / playbook update pass.
REFLECTION_MODEL=claude-opus-4-8

# Default Monte Carlo iterations for the true-equity truth layer.
EQUITY_ITERATIONS=2000

# SQLite database path.
DATABASE_PATH=./data/poker.db
